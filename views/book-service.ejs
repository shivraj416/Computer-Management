<!DOCTYPE html>
<html>
<head>
<title>Book Service</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="icon" type="image/png" sizes="512x512" href="/images/favicon-512.png">

<style>

/* ===== FULL BACKGROUND IMAGE ===== */
body {
    margin: 0;
    min-height: 100vh;
    background: url('/images/service-bg.jpg') no-repeat center center/cover;
    font-family: 'Segoe UI', sans-serif;
    position: relative;
}

/* DARK OVERLAY */
body::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 0;
}

/* PAGE WRAPPER */
.page-content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 90vh;
}

/* GLASS CARD */
.booking-card {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(15px);
    border-radius: 20px;
    padding: 40px;
    width: 450px;
    color: white;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6);
}

/* FORM STYLING */
.form-control {
    background: rgba(255,255,255,0.2);
    border: none;
    color: white;
}

.form-control::placeholder {
    color: rgba(255,255,255,0.7);
}

.form-control:focus {
    background: rgba(255,255,255,0.3);
    color: white;
}

/* BUTTON */
.btn-book {
    background: linear-gradient(45deg,#00c6ff,#0072ff);
    border: none;
    border-radius: 25px;
    transition: 0.3s;
}

.btn-book:hover {
    transform: scale(1.05);
}

</style>
</head>

<body>

<!-- ✅ NAVBAR -->
<%- include('partials/navbar') %>

<!-- PAGE CONTENT -->
<div class="container page-content">

<div class="booking-card">

<h3 class="text-center mb-4">📅 Book Service Appointment</h3>

<% if (typeof success !== 'undefined') { %>
<div class="alert alert-success text-center">
Appointment Booked Successfully!
</div>
<% } %>

<form action="/book-service" method="POST">

<input type="text" name="name" class="form-control mb-3" placeholder="Your Name" required>

<input type="email" name="email" class="form-control mb-3" placeholder="Your Email" required>

<input type="text" name="phone" class="form-control mb-3" placeholder="Phone Number" required>

<select name="service" class="form-control mb-3" required>
<option value="">Select Service</option>
<option>Computer Repair</option>
<option>Laptop Service</option>
<option>Software Installation</option>
<option>Hardware Upgrade</option>
</select>

<input type="date" name="date" class="form-control mb-3" required>

<input type="time" name="time" class="form-control mb-3" required>

<button type="submit" class="btn btn-book w-100">Book Now</button>

</form>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>