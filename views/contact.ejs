<!DOCTYPE html>
<html>
<head>
<title>Contact Us</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="icon" type="image/png" sizes="512x512" href="/images/favicon-512.png">

<style>
body {
    margin: 0;
    min-height: 100vh;
    background: url('/images/contact.jpg') no-repeat center center/cover;
    font-family: 'Segoe UI', sans-serif;
    position: relative;
}

/* DARK OVERLAY */
body::before {
    content: "";
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 0;
}

/* CONTENT WRAPPER */
.page-wrapper {
    position: relative;
    z-index: 2;
    padding-top: 100px;   /* space below navbar */
}

/* CONTACT CARD */
.contact-card {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(15px);
    border-radius: 25px;
    padding: 40px;
    color: white;
    box-shadow: 0 25px 70px rgba(0,0,0,0.6);
}

.contact-title {
    font-weight: 700;
    font-size: 28px;
}

/* INPUT STYLE */
.form-control {
    background: rgba(255,255,255,0.15);
    border: none;
    color: white;
}

.form-control::placeholder {
    color: rgba(255,255,255,0.7);
}

.form-control:focus {
    background: rgba(255,255,255,0.25);
    color: white;
}

/* BUTTON */
.btn-submit {
    background: linear-gradient(45deg,#00c6ff,#0072ff);
    border: none;
    border-radius: 30px;
    padding: 10px 25px;
    color: white;
    transition: 0.3s ease;
}

.btn-submit:hover {
    transform: scale(1.05);
}

.contact-info {
    font-size: 15px;
    margin-top: 20px;
}
</style>
</head>

<body>

<!-- ✅ NAVBAR ADDED -->
<%- include('partials/navbar') %>

<div class="container page-wrapper">
<div class="row justify-content-center">
<div class="col-md-6">

<div class="contact-card">

<h2 class="contact-title mb-4 text-center">📞 Contact Us</h2>

<!-- SUCCESS MESSAGE -->
<% if (typeof success !== 'undefined') { %>
<div class="alert alert-success text-center">
Message Sent Successfully!
</div>
<% } %>

<form action="/send-message" method="POST">
<input type="text" name="name" class="form-control mb-3" placeholder="Your Name" required>
<input type="email" name="email" class="form-control mb-3" placeholder="Your Email" required>
<textarea name="message" class="form-control mb-3" rows="4" placeholder="Your Message" required></textarea>

<div class="text-center">
<button type="submit" class="btn btn-submit">Send Message</button>
</div>
</form>

<hr>

<div class="contact-info text-center">
<p>📍 Gadhinglaj, Maharashtra</p>
<p>📧 pp2391346@gmail.com</p>
<p>📞 +91 8329806466</p>
</div>

</div>

</div>
</div>
</div>

</body>
</html>