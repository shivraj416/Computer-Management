<!DOCTYPE html>
<html>

<head>
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="icon" type="image/png" sizes="512x512" href="/images/favicon-512.png">

    <style>
        /* ===== FULL BACKGROUND IMAGE ===== */
        body {
            margin: 0;
            min-height: 100vh;
            background: url('/images/admin.jpg') no-repeat center center/cover;
            font-family: 'Segoe UI', sans-serif;
            position: relative;
            display: flex;
            align-items: center;
        }

        /* ===== DARK OVERLAY ===== */
        body::before {
            content: "";
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.55);
            z-index: 0;
        }

        /* ===== MAIN CONTAINER ===== */
        .dashboard-container {
            position: relative;
            z-index: 2;
        }

        /* ===== TITLE ===== */
        .dashboard-title {
            color: white;
            font-weight: 700;
            font-size: 32px;
            text-align: center;
        }

        /* ===== GLASS CARDS ===== */
        .dashboard-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            color: white;
            transition: 0.3s ease;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
        }

        .dashboard-card:hover {
            transform: translateY(-8px);
        }

        /* ===== BUTTON STYLING ===== */
        .btn-custom {
            border-radius: 25px;
            padding: 8px 20px;
        }
    </style>
</head>

<body>

    <div class="container dashboard-container mt-5">

        <h2 class="dashboard-title mb-5">💻 Admin Dashboard</h2>

        <div class="row">

            <div class="col-md-4 mb-4">
                <div class="dashboard-card p-4 text-center">
                    <h4>📦 Products</h4>
                    <a href="/products" class="btn btn-info btn-custom mt-3">Manage</a>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="dashboard-card p-4 text-center">
                    <h4>👥 Customers</h4>
                    <a href="/customers" class="btn btn-success btn-custom mt-3">Manage</a>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="dashboard-card p-4 text-center">
                    <h4>🛠 Services</h4>
                    <a href="/services" class="btn btn-warning btn-custom mt-3">Manage</a>
                </div>
            </div>

            <div class="row mt-5">

                <div class="col-md-6 mb-4">
                    <div class="dashboard-card p-4 text-center">
                        <h4>📊 Total Logins</h4>
                        <h2>
                            <%= totalLogins %>
                        </h2>
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <div class="dashboard-card p-4 text-center">
                        <h4>📈 Logins Today</h4>
                        <h2>
                            <%= todayLogins %>
                        </h2>
                    </div>
                </div>

            </div>

        </div>
    </div>

</body>

</html>