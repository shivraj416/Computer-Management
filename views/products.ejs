<!DOCTYPE html>
<html>

<head>
    <title>Products</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="icon" type="image/png" sizes="512x512" href="/images/favicon-512.png">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('partials/navbar') %>

        <div class="container mt-5">
            <h2>Product Management</h2>

            <!-- ADD PRODUCT FORM -->
            <form action="/add-product" method="POST" class="row g-3 mb-4">
                <div class="col-md-3">
                    <input type="text" name="name" placeholder="Product Name" class="form-control" required>
                </div>
                <div class="col-md-3">
                    <input type="text" name="brand" placeholder="Brand" class="form-control" required>
                </div>
                <div class="col-md-2">
                    <input type="number" name="price" placeholder="Price" class="form-control" required>
                </div>
                <div class="col-md-2">
                    <input type="number" name="quantity" placeholder="Quantity" class="form-control" required>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-info w-100">Add Product</button>
                </div>
            </form>

            <!-- PRODUCTS TABLE -->
            <table class="table table-dark table-striped">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Brand</th>
                    <th>Price</th>
                    <th>Qty</th>
                    <th>Sell</th>
                    <th>Delete</th>
                </tr>

                <% products.forEach(product=> { %>
                    <tr>
                        <td>
                            <%= product.id %>
                        </td>
                        <td>
                            <%= product.name %>
                        </td>
                        <td>
                            <%= product.brand %>
                        </td>
                        <td>₹<%= product.price %>
                        </td>
                        <td>
                            <%= product.quantity %>
                        </td>

                        <!-- SELL FORM (CORRECT POSITION) -->
                        <td>
                            <form action="/sell-product" method="POST" class="d-flex">
                                <input type="hidden" name="id" value="<%= product.id %>">
                                <input type="number" name="quantity" min="1" max="<%= product.quantity %>" required
                                    class="form-control form-control-sm me-2" style="width:80px;">
                                <button class="btn btn-success btn-sm">Sell</button>
                            </form>
                        </td>

                        <!-- DELETE BUTTON -->
                        <td>
                            <a href="/delete-product/<%= product.id %>" class="btn btn-danger btn-sm">
                                Delete
                            </a>
                        </td>

                    </tr>
                    <% }) %>

            </table>
        </div>

        <%- include('partials/footer') %>
</body>

</html>