<!DOCTYPE html>
<html>
<head>
<title>Services</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="icon" type="image/png" sizes="512x512" href="/images/favicon-512.png">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar') %>

<div class="container mt-5">
<h2>Service Management</h2>

<form action="/add-service" method="POST" class="row g-3">
<input type="text" name="customer" placeholder="Customer Name" class="form-control" required>
<textarea name="issue" placeholder="Issue Description" class="form-control" required></textarea>
<input type="text" name="status" placeholder="Status" class="form-control" required>
<input type="number" name="charges" placeholder="Charges" class="form-control" required>
<button class="btn btn-warning mt-2">Add Service</button>
</form>

<table class="table table-dark table-striped mt-4">
<tr>
<th>ID</th><th>Customer</th><th>Issue</th><th>Status</th><th>Charges</th><th>Action</th>
</tr>

<% services.forEach(service => { %>
<tr>
<td><%= service.id %></td>
<td><%= service.customer %></td>
<td><%= service.issue %></td>
<td><%= service.status %></td>
<td><%= service.charges %></td>
<td>
<a href="/delete-service/<%= service.id %>" class="btn btn-danger btn-sm">
Delete
</a>
</td>
</tr>
<% }) %>

</table>
</div>

<%- include('partials/footer') %>
</body>
</html>