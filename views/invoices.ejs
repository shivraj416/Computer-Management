<!DOCTYPE html>
<html>
<head>
<title>Invoice Dashboard</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="icon" type="image/png" sizes="512x512" href="/images/favicon-512.png">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body {
    background: linear-gradient(135deg, #141e30, #243b55);
    color: white;
    font-family: 'Segoe UI', sans-serif;
}

.page-title {
    font-weight: 700;
    font-size: 28px;
    background: linear-gradient(45deg, #00f2fe, #4facfe);
    -webkit-background-clip: text;
    color: transparent;
}

.invoice-card {
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(15px);
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.1);
}

.summary-box {
    background: linear-gradient(45deg,#00c6ff,#0072ff);
    padding: 20px;
    border-radius: 15px;
    text-align: center;
}

.btn-view {
    background: linear-gradient(45deg,#11998e,#38ef7d);
    border: none;
    border-radius: 20px;
    color: white;
}

.btn-delete {
    border-radius: 20px;
}
</style>
</head>

<body>

<%- include('partials/navbar') %>

<div class="container mt-5">

<h2 class="page-title mb-4">📄 Invoice Dashboard</h2>

<!-- SUMMARY -->
<div class="row mb-4">
<div class="col-md-4">
<div class="summary-box">
<h5>Total Invoices</h5>
<h3><%= sales.length %></h3>
</div>
</div>

<div class="col-md-4">
<div class="summary-box">
<h5>Total Revenue</h5>
<h3>
₹<%= sales.reduce((sum, s) => sum + Number(s.total), 0).toFixed(2) %>
</h3>
</div>
</div>
</div>

<!-- SEARCH + FILTER + EXPORT -->
<div class="invoice-card p-4 mb-4">
<div class="row">
<div class="col-md-4">
<input type="text" id="searchInput" class="form-control" placeholder="🔍 Search Product">
</div>
<div class="col-md-4">
<input type="date" id="dateFilter" class="form-control">
</div>
<div class="col-md-4 text-end">
<a href="/export-invoices" class="btn btn-success">
📄 Export CSV
</a>
</div>
</div>
</div>

<!-- TABLE -->
<div class="invoice-card p-4">
<table class="table table-dark table-striped" id="invoiceTable">
<thead>
<tr>
<th>ID</th>
<th>Date</th>
<th>Product</th>
<th>Qty</th>
<th>Total</th>
<th>Action</th>
</tr>
</thead>
<tbody>

<% sales.forEach(sale => { %>
<tr>
<td>#<%= sale.id %></td>
<td><%= sale.date %></td>
<td><%= sale.product %></td>
<td><%= sale.quantity %></td>
<td>₹<%= Number(sale.total).toFixed(2) %></td>
<td>
<a href="/invoice/<%= sale.id %>" class="btn btn-view btn-sm">View</a>
<a href="/delete-invoice/<%= sale.id %>" class="btn btn-danger btn-delete btn-sm">🗑</a>
</td>
</tr>
<% }) %>

</tbody>
</table>
</div>

<!-- GRAPH -->
<div class="invoice-card p-4 mt-4">
<canvas id="salesChart"></canvas>
</div>

</div>

<script>

// SEARCH
document.getElementById("searchInput").addEventListener("keyup", function() {
let filter = this.value.toLowerCase();
let rows = document.querySelectorAll("#invoiceTable tbody tr");

rows.forEach(row => {
let product = row.cells[2].textContent.toLowerCase();
row.style.display = product.includes(filter) ? "" : "none";
});
});

// DATE FILTER
document.getElementById("dateFilter").addEventListener("change", function() {
let selected = this.value;
let rows = document.querySelectorAll("#invoiceTable tbody tr");

rows.forEach(row => {
let dateText = row.cells[1].textContent;
row.style.display = dateText.includes(selected) ? "" : "none";
});
});

// CHART
const ctx = document.getElementById('salesChart');
const monthlyTotal = {};

new Chart(ctx, {
type: 'bar',
data: {
labels: Object.keys(monthlyTotal),
datasets: [{
label: 'Monthly Sales',
data: Object.values(monthlyTotal)
}]
}
});

</script>

</body>
</html>