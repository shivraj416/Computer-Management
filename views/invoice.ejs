<!DOCTYPE html>
<html>
<head>
<title>Invoice</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="icon" type="image/png" sizes="512x512" href="/images/favicon-512.png">

<style>

/* ===== BACKGROUND ===== */
body {
    background: linear-gradient(135deg, #141e30, #243b55);
    font-family: 'Segoe UI', sans-serif;
    color: white;
}

/* ===== INVOICE CARD ===== */
.invoice-wrapper {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(15px);
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.1);
}

/* ===== TITLE ===== */
.invoice-title {
    font-weight: 700;
    font-size: 30px;
    background: linear-gradient(45deg, #00f2fe, #4facfe);
    -webkit-background-clip: text;
    color: transparent;
}

.invoice-subtitle {
    color: rgba(255,255,255,0.7);
}

/* ===== DIVIDER ===== */
.invoice-divider {
    border-top: 1px solid rgba(255,255,255,0.2);
}

/* ===== TOTAL BOX ===== */
.total-box {
    background: linear-gradient(45deg, #00c6ff, #0072ff);
    border-radius: 15px;
    color: white;
    box-shadow: 0 10px 30px rgba(0,114,255,0.5);
}

.total-box h3 {
    font-size: 28px;
    font-weight: bold;
}

/* ===== PRINT BUTTON ===== */
.invoice-print-btn {
    background: linear-gradient(45deg, #11998e, #38ef7d);
    border: none;
    border-radius: 30px;
    color: white;
    transition: 0.3s ease;
}

.invoice-print-btn:hover {
    transform: scale(1.05);
}

/* ===== FOOTER TEXT ===== */
.invoice-footer-text {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
}

/* ===== PRINT STYLE ===== */
@media print {
    body {
        background: white !important;
        color: black !important;
    }

    .invoice-wrapper {
        background: white !important;
        box-shadow: none !important;
        border: none !important;
        color: black !important;
    }

    .no-print {
        display: none;
    }
}

</style>

</head>
<body>

<%- include('partials/navbar') %>

<div class="container mt-5">
<div class="invoice-wrapper p-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="invoice-title">🧾 INVOICE</h2>
            <p class="invoice-subtitle">Computer Sales & Service</p>
        </div>
        <div class="text-end">
            <p class="mb-1"><strong>Invoice No:</strong> #<%= sale.id %></p>
            <p class="mb-1"><strong>Date:</strong> <%= sale.date %></p>
        </div>
    </div>

    <hr class="invoice-divider">

    <!-- BILL DETAILS -->
    <div class="row mt-4">
        <div class="col-md-8">
            <p><strong>Product:</strong> <%= sale.product %></p>
            <p><strong>Quantity:</strong> <%= sale.quantity %></p>
            <p><strong>Unit Price:</strong> ₹<%= Number(sale.price).toFixed(2) %></p>
        </div>

        <div class="col-md-4 text-end">
            <div class="total-box p-4">
                <h5>Grand Total</h5>
                <h3>₹<%= Number(sale.total).toFixed(2) %></h3>
            </div>
        </div>
    </div>

    <hr class="invoice-divider">

    <!-- FOOTER -->
    <div class="text-center mt-4">
        <p class="invoice-footer-text">
            Thank you for your business! <br>
            For support contact: support@computersystem.com
        </p>
    </div>

    <div class="text-center mt-4 no-print">
        <button onclick="window.print()" class="btn invoice-print-btn px-4">
            🖨 Print Invoice
        </button>
    </div>

</div>
</div>

</body>
</html>